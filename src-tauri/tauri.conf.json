{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Note Reader",
  "version": "0.1.1",
  "identifier": "com.wangda.note-reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Note Reader",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
